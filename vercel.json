{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "client/assets/$1",
      "continue": true
    },
    {
      "src": "/(.*).(js|css|png|jpg|jpeg|svg|ico|json)",
      "dest": "client/$1.$2",
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "client/index.html"
    }
  ]
}